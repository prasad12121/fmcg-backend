MONGO_URI=mongodb://127.0.0.1:27017/fmcg
PORT=5001
JWT_SECRET=change_me_in_production

# Optional: comma-separated frontend origins for CORS (defaults to allow all)
# CLIENT_URL=http://localhost:5173

# Email (required in production). In development, OTP is logged to the backend console when SMTP is omitted.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM="FMCG <noreply@example.com>"
